[Unit]
Description=在庫引当ツール
After=network.target

[Service]
User=ubuntu
WorkingDirectory=/home/ubuntu/zaiko-tool/app
Environment="PATH=/home/ubuntu/zaiko-tool/app/venv/bin"
EnvironmentFile=/home/ubuntu/zaiko-tool/app/.env
ExecStart=/home/ubuntu/zaiko-tool/app/venv/bin/gunicorn -w 2 --timeout 900 --bind 0.0.0.0:5000 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
