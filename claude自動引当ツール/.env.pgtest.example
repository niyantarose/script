# PostgreSQL テスト接続用（本番 .env とは別ファイルに置く）
# コピー: cp .env.pgtest.example .env.pgtest して値を埋める

USE_SQLITE=false
DATABASE_URL=postgresql+psycopg://zaiko_app:パスワード@127.0.0.1:5432/zaiko_inventory_test

# DATABASE_URL を使わない場合の代替（URL エンコードが必要な文字は config 側で quote されます）
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_NAME=zaiko_inventory_test
# DB_USER=zaiko_app
# DB_PASSWORD=

# アプリ用（本番と同様に設定）
# SECRET_KEY=...
