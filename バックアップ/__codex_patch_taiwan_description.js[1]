const fs = require('fs');
const path = require('path');
const root = 'Z:/script';
const extDir = fs.readdirSync(root, { withFileTypes: true })
  .find(entry => entry.isDirectory() && entry.name.includes('商品登録拡張機能'));
if (!extDir) throw new Error('extension directory not found');
const file = path.join(root, extDir.name, 'content', 'taiwan', 'content.js');
let text = fs.readFileSync(file, 'utf8');

const oldLine = `    description = baseDescription;`;
const newLine = `    description = mergeTextBlocks([\n      baseDescription,\n      extendedContent.text,\n      firstEditionBonus.text,\n    ]);`;
if (!text.includes(oldLine)) throw new Error('description line not found');
text = text.replace(oldLine, newLine);
fs.writeFileSync(file, text, 'utf8');
console.log(file);
